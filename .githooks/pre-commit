#!/bin/sh
#
# BTG v4 — Pre-Commit Hook
# 
# Validates project structure before allowing commits
# Enforces PROJECT_STRUCTURE_RULES.md compliance
#
# This hook runs automatically before every commit
# Exit code 0 = commit proceeds
# Exit code 1 = commit blocked
#

echo ""
echo "╔════════════════════════════════════════════════════════╗"
echo "║  BTG v4 — Pre-Commit Structure Validation             ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""

# Check if we're in the correct directory
if [ ! -f "scripts/validate-structure.js" ]; then
  echo "⚠️  Warning: validate-structure.js not found"
  echo "   Hook may be running from wrong directory"
  echo ""
fi

# Run structure validation from project root
echo "🔍 Running structure validation..."
echo ""

# Change to project root (parent of .githooks)
cd "$(dirname "$0")/.." || exit 1

# Run validation using node directly (more reliable than npm in hooks)
node scripts/validate-structure.js

# Capture exit code
VALIDATION_EXIT_CODE=$?

echo ""

# Check validation result
if [ $VALIDATION_EXIT_CODE -ne 0 ]; then
  echo "╔════════════════════════════════════════════════════════╗"
  echo "║  ❌ COMMIT BLOCKED: Structure Violations Found        ║"
  echo "╚════════════════════════════════════════════════════════╝"
  echo ""
  echo "Your commit has been blocked because structure rule"
  echo "violations were detected."
  echo ""
  echo "📋 Next Steps:"
  echo "   1. Review the violations listed above"
  echo "   2. Fix each violation (move files, add missing files, etc.)"
  echo "   3. Stage your fixes: git add <files>"
  echo "   4. Try committing again: git commit"
  echo ""
  echo "💡 Tips:"
  echo "   • Check PROJECT_STRUCTURE_RULES.md for guidelines"
  echo "   • Run 'npm run validate:structure' to test fixes"
  echo "   • Ask for help if violations are unclear"
  echo ""
  echo "⚠️  To bypass this hook (NOT RECOMMENDED):"
  echo "   git commit --no-verify"
  echo ""
  exit 1
fi

# Validation passed
echo "╔════════════════════════════════════════════════════════╗"
echo "║  ✅ Structure Validation Passed                        ║"
echo "╚════════════════════════════════════════════════════════╝"
echo ""
echo "Your commit meets all structure requirements."
echo "Proceeding with commit..."
echo ""

exit 0
